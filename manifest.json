{
  "manifest_version": 3,
  "name": "RSVP Chunking Reader - Pro",
  "version": "2.0",
  "description": "Improve your reading speed up to 1000 WPM using semantic text chunking.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "RSVP Settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["libs/compromise.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "start-rsvp": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Start RSVP from selected text"
    },
    "in-page-chunk": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "MacCtrl+Shift+E"
      },
      "description": "Chunk directly in the webpage"
    }
  }
}
